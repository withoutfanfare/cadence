# Cadence configuration — copy to cadence/.env (gitignored) and fill in.
# Scheduled launchd jobs still use the root .env fallback until per-project
# launchd config support lands.
# No real values are committed; this file holds everything deployment-specific.

# — Linear —
LINEAR_API_KEY=lin_api_xxx          # personal API key (Linear → Settings → API)
LINEAR_TEAM_ID=
LINEAR_PROJECT_ID=
LINEAR_TEAM_NAME=                   # quote names with spaces, e.g. "Example Team"
LINEAR_ASSIGNEE_ID=                 # only act on issues assigned to this user

# — Code repo the build loop works in —
REPO_SLUG=owner/name
BASE_BRANCH=develop
PROJECT_DIR=/Users/you/Code/app
WORKTREE_BASE=/Users/you/Code/app-worktrees
WORKTREE_TOOL=git                   # git (default; needs only Git) | grove (Laravel Herd sites)

# — AI provider roles —
# Use `cadence providers roles` to see what each slot does.
# Use `cadence providers set ...` for routine changes; it updates this file shape
# in your active config.
#
# ORCHESTRATOR_* values are provider:model pairs for the lead model running each
# Cadence loop. Supported providers: claude | codex | kimi | opencode.
#
# ORCHESTRATOR_PROVIDER is only the fallback provider used when a per-stage
# ORCHESTRATOR_* value is missing or omits `provider:`. Keep it aligned with the
# normal/default provider for the profile.
ORCHESTRATOR_PROVIDER=claude

# Per-stage lead orchestrators.
ORCHESTRATOR_TRIAGE=claude:sonnet
ORCHESTRATOR_SPEC=claude:opus
ORCHESTRATOR_BUILD=claude:opus
ORCHESTRATOR_REVISE=claude:sonnet
ORCHESTRATOR_ADVANCE=claude:sonnet

# Legacy Claude model aliases kept as fallback defaults for existing profiles.
# These are model names only. Do not put provider:model values here.
# Wrong: MODEL_BUILD=codex:gpt-5.4
# Right: ORCHESTRATOR_BUILD=codex:gpt-5.4
MODEL_TRIAGE=sonnet
MODEL_SPEC=opus
MODEL_BUILD=opus
MODEL_REVISE=sonnet
MODEL_ADVANCE=sonnet

# Folded PR/diff review is separate from the loop orchestrator.
REVIEW_PROVIDER=claude
REVIEW_MODEL=opus

# BUILD_IMPLEMENTER is the provider that writes code inside the build worktree.
# It is provider-only, not provider:model. Use `codex`, not `codex:gpt-5.4`.
BUILD_IMPLEMENTER=claude            # claude|kimi|opencode|codex
NOTIFY=on                           # macOS notifications
RUNNER_PATH_PREPEND=                # optional; prepended to PATH for loop runners

# — Autonomous mode (opt-in; Layer 1 advancer) —
AUTONOMOUS=0                        # 1/on to let the advancer grant gates on agent:auto issues
AUTO_MAX_ISSUES_PER_RUN=1           # cap issues advanced per run; raise once trusted
AUTO_MAX_REPAIRS=3                  # build↔revise repair attempts before handing back to a human
AUTO_COST_CEILING=                  # reserved; per-run cost is logged, not yet enforced
CONDUCT_WIP=1                       # max issues in autonomous flight at once (the conductor's WIP cap)

# — Verification gates (profile-specific; blank to skip) —
GATE_LINT=
GATE_TEST=
GATE_ANALYSE=

# — Memory —
MEMORY_BACKEND=markdown             # markdown | clio
MEMORY_DIR=                         # markdown backend; default: $CADENCE_HOME/memory
MEMORY_NAMESPACE=                   # only used when backend=clio

# — Runtime (optional overrides) —
CADENCE_STATE_DIR=                  # default: $HOME/.cadence
